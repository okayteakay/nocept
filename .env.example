# Invoice Exception Resolution System — Environment Variables
# Copy this file to .env and fill in the values for your environment

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# OpenAI-Compatible LLM (must support vision for image/PDF parsing)
# ============================================================================
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Business Rules
# ============================================================================
PRICE_TOLERANCE_PCT=0.01
QTY_TOLERANCE_PCT=0.02

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
