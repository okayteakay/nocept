REDIS_URL=redis://localhost:6379/0
TAVILY_API_KEY=your_tavily_api_key_here
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_project_id_here
PRICE_TOLERANCE_PCT=0.05
QTY_TOLERANCE_PCT=0.02
AUTO_RESOLVE_MAX_VARIANCE_USD=500
LOG_LEVEL=INFO

# Knowledge base / vector search
# Requires Redis Stack (see docker-compose.yml).
# Model is downloaded from HuggingFace on first run (~90 MB, cached locally).
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSIONS=384
VECTOR_INDEX_PREFIX=kb:
