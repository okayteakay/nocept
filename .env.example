# Invoice Exception Resolution System — Environment Variables
# Copy this file to .env and fill in the values for your environment

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Celery (Async Worker)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================================================
# OpenAI-Compatible LLM (for comms checking)
# ============================================================================
OPENAI_API_KEY=sk-nano-...
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Tavily Web Search (for exception research)
# ============================================================================
TAVILY_API_KEY=tvly-dev-...

# ============================================================================
# Business Rules
# ============================================================================
PRICE_TOLERANCE_PCT=0.01
QTY_TOLERANCE_PCT=0.02

# ============================================================================
# Knowledge Base / Vector Embeddings
# ============================================================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSIONS=384
VECTOR_INDEX_PREFIX=kb:

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# Notifications — Slack
# ============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ESCALATION_CHANNEL=#ap-escalations

# ============================================================================
# Notifications — Email (SMTP)
# ============================================================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=noreply@meridian-ap.local
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@meridian-ap.local
NOTIFICATION_EMAIL_TO=ap-team@company.com,manager@company.com

# ============================================================================
# SAP Webhook Security
# ============================================================================
# HMAC-SHA256 shared secret — set a strong random value in production
SAP_WEBHOOK_SECRET=your-secret-key-change-in-production

# ============================================================================
# JWT / OAuth2 Authentication
# ============================================================================
# Generate a strong secret in production: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
