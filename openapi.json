    "/documents/parse": {
      "post": {
        "tags": [
          "Documents"
        ],
        "summary": "Parse a PDF document via OCR + LLM",
        "description": "Upload a PDF (invoice, PO, or GRN) and receive the parsed Pydantic model. OCR uses Tesseract; structured extraction uses the configured OpenAI-compatible LLM. The endpoint does NOT auto-create an exception \u2014 review the parsed model, then call /webhook/invoice, /webhook/po, or /webhook/grn to enqueue it.",
        "operationId": "parse_document_documents_parse_post",
        "parameters": [
          {
            "name": "doc_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Doc Type"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_parse_document_documents_parse_post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentParseResponse"
                }
