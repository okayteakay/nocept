{
  "openapi": "3.1.0",
  "info": {
    "title": "Invoice Exception Resolution \u2014 Dashboard & KB API",
    "description": "RESTful API for the autonomous LangGraph agent: dashboard search, human approval, knowledge-base search, and analytics. The six-gate decision pipeline runs asynchronously via Celery.",
    "version": "4.0.0"
  },
  "paths": {
    "/auth/token": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Login For Access Token",
        "description": "OAuth2 login endpoint.\n\nIssues access_token (short-lived, 30min) and refresh_token (long-lived, 7 days).\n\nArgs:\n    form_data: OAuth2 password flow request (username + password)\n\nReturns:\n    Token with access and refresh tokens\n\nRaises:\n    HTTPException: if credentials are invalid",
        "operationId": "login_for_access_token_auth_token_post",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/Body_login_for_access_token_auth_token_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Token"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Refresh Access Token",
        "description": "Refresh an access token using a refresh token.\n\nArgs:\n    refresh_token: Valid refresh token\n\nReturns:\n    New access and refresh tokens\n\nRaises:\n    HTTPException: if refresh token is invalid",
        "operationId": "refresh_access_token_auth_refresh_post",
        "parameters": [
          {
            "name": "refresh_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Refresh Token"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Token"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Read Users Me",
        "description": "Get the current authenticated user.\n\nArgs:\n    current_user: Current user from JWT token\n\nReturns:\n    User information",
        "operationId": "read_users_me_auth_me_get",
        "responses": {
